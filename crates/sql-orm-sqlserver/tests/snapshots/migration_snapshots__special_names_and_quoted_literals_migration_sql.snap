GO
CREATE TABLE [tenant's archive]]2026].[orders; GO] (
    [id] bigint NOT NULL,
    [display]] name] nvarchar(120) NOT NULL DEFAULT N'O''Brien; still literal',
    CONSTRAINT [pk_orders; go] PRIMARY KEY ([id])
)
GO
