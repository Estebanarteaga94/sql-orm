SQL: SELECT [sales].[navigation_targets].[id] AS [id], [sales].[navigation_targets].[owner_id] AS [owner_id], [owner].[id] AS [owner__id] FROM [sales].[navigation_targets] LEFT JOIN [dbo].[navigation_roots] AS [owner] ON (([sales].[navigation_targets].[owner_id] = [owner].[id]) AND ([owner].[deleted_at] IS NULL)) WHERE ([owner].[id] > @P1) ORDER BY [owner].[id] DESC OFFSET @P2 ROWS FETCH NEXT @P3 ROWS ONLY
