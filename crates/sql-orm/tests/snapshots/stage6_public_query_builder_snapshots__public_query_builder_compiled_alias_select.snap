SQL: SELECT [u].[email] AS [email], [created_orders].[total_cents] AS [total_cents] FROM [dbo].[snapshot_users] AS [u] INNER JOIN [dbo].[snapshot_orders] AS [created_orders] ON ([u].[id] = [created_orders].[user_id]) LEFT JOIN [dbo].[snapshot_orders] AS [completed_orders] ON ([completed_orders].[total_cents] >= @P1) WHERE ([created_orders].[total_cents] >= @P2) ORDER BY [completed_orders].[total_cents] DESC OFFSET @P3 ROWS FETCH NEXT @P4 ROWS ONLY
Params:
1: I64(5000)
2: I64(1000)
3: I64(0)
4: I64(10)
